{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Android: Build (assembleDebug)",
      "type": "shell",
      "command": "gradle",
      "args": ["assembleDebug"],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "Android: Install APK",
      "type": "shell",
      "command": "${env:LOCALAPPDATA}/Android/Sdk/platform-tools/adb.exe",
      "args": [
        "install",
        "-r",
        "${workspaceFolder}/app/build/outputs/apk/debug/app-debug.apk"
      ],
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Android: Launch app",
      "type": "shell",
      "command": "${env:LOCALAPPDATA}/Android/Sdk/platform-tools/adb.exe",
      "args": [
        "shell",
        "am",
        "start",
        "-n",
        "cz.jirnec.callandsmsstats/.MainActivity"
      ],
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Android: Build + Install + Launch",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Android: Build (assembleDebug)",
        "Android: Install APK",
        "Android: Launch app"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Android: Devices (adb)",
      "type": "shell",
      "command": "${env:LOCALAPPDATA}/Android/Sdk/platform-tools/adb.exe",
      "args": ["devices"],
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
