<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Ostré rohy pro všechny Material komponenty (karty, chips, tlačítka…). -->
    <style name="ShapeAppearance.App.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">0dp</item>
    </style>

    <style name="ShapeAppearance.App.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">0dp</item>
    </style>

    <style name="ShapeAppearance.App.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">0dp</item>
    </style>

    <!-- Filtrovací chip s ostrými rohy a barvou vybraného stavu podle motivu. -->
    <style name="Widget.App.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">0dp</item>
        <item name="chipBackgroundColor">@color/chip_container</item>
        <item name="android:textColor">@color/chip_label</item>
        <item name="checkedIconTint">?attr/colorOnPrimary</item>
        <item name="chipStrokeColor">?attr/colorOutline</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

    <style name="Theme.CallAndSMSStats" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.App.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.App.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.App.Large</item>
    </style>

</resources>
